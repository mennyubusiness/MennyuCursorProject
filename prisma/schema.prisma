generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pod {
  id                 String                 @id @default(cuid())
  name               String
  slug               String                 @unique
  description        String?
  imageUrl           String?
  /// Customer-facing accent, e.g. #1d4ed8 — validated app-side; null = default Mennyu styling.
  accentColor        String?
  address            String?
  latitude           Float?
  longitude          Float?
  /// IANA timezone for scheduled pickup (e.g. America/Chicago). Falls back to DEFAULT_PICKUP_TIMEZONE env when null.
  pickupTimezone     String?
  /// Pickup-only sales tax rate in basis points (e.g. 825 = 8.25%). Applied to food subtotal by Mennyu at checkout — not vendor-entered per order. Null/omit = no automatic tax.
  pickupSalesTaxBps  Int?
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  carts              Cart[]
  orders             Order[]
  membershipRequests PodMembershipRequest[]
  vendors            PodVendor[]
  memberships        PodMembership[]
}

model PodVendor {
  id         String   @id @default(cuid())
  podId      String
  vendorId   String
  sortOrder  Int      @default(0)
  /// Presentation: featured vendors sort before others (then by sortOrder).
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pod       Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([podId, vendorId])
  @@index([podId])
  @@index([vendorId])
}

/// Pod membership request: pod owner requests vendor to join; vendor must accept or decline.
model PodMembershipRequest {
  id          String    @id @default(cuid())
  podId       String
  vendorId    String
  /// pending | accepted | declined | cancelled
  status      String
  requestedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?
  pod         Pod       @relation(fields: [podId], references: [id], onDelete: Cascade)
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([podId])
  @@index([vendorId])
  @@index([vendorId, status])
}

/// Unified auth: one User can hold multiple role-specific memberships (vendor first; pod/customer/admin later).
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendorMemberships VendorMembership[]
  podMemberships    PodMembership[]
  /// Platform (Mennyu internal) admin; same User + session as vendors. Complements temporary ADMIN_SECRET cookie bridge.
  isPlatformAdmin Boolean @default(false)
}

enum PodMembershipRole {
  owner
  manager
}

/// User ↔ pod: contextual access for pod dashboard (curation, membership requests). Not a global role.
model PodMembership {
  id        String            @id @default(cuid())
  userId    String
  podId     String
  role      PodMembershipRole @default(manager)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@unique([userId, podId])
  @@index([podId])
  @@index([userId])
}

enum VendorMembershipRole {
  owner
  staff
}

model VendorMembership {
  id        String               @id @default(cuid())
  userId    String
  vendorId  String
  role      VendorMembershipRole @default(staff)
  createdAt DateTime             @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([userId, vendorId])
  @@index([vendorId])
  @@index([userId])
}

model Vendor {
  id                      String                 @id @default(cuid())
  name                    String
  slug                    String                 @unique
  description             String?
  imageUrl                String?
  /// Customer-facing brand accent, e.g. #c2410c — validated app-side; null = use default Mennyu styling.
  accentColor             String?
  isActive                Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  deliverectChannelLinkId String?
  deliverectLocationId    String?
  deliverectAccountId     String?
  /// When true, block new Mennyu orders for this vendor (intake only); existing orders still visible.
  mennyuOrdersPaused      Boolean                @default(false)
  /// When true, Deliverect menu webhook imports may auto-publish when eligibility rules pass (see menu-auto-publish.service).
  autoPublishMenus        Boolean                @default(false)
  /// Legacy: shared secret for Bearer/automation and magic-link cookie bootstrap. Prefer User session + VendorMembership.
  vendorDashboardToken    String?
  cartItems               CartItem[]
  menuItems               MenuItem[]
  modifierGroups          ModifierGroup[]
  podMembershipRequests   PodMembershipRequest[]
  pods                    PodVendor[]
  vendorOrders            VendorOrder[]
  menuImportJobs          MenuImportJob[]
  menuVersions            MenuVersion[]
  vendorMemberships       VendorMembership[]
}

// ---- Deliverect-first menu import (Phase 1B: draft only; no live MenuItem writes) ----

enum MenuImportSource {
  DELIVERECT_API_PULL
  DELIVERECT_MENU_WEBHOOK
}

enum MenuImportJobStatus {
  queued
  fetching
  ingested
  normalizing
  validating
  awaiting_review
  publishing
  succeeded
  failed
  cancelled
}

enum MenuImportIssueSeverity {
  blocking
  warning
  info
}

enum MenuImportIssueKind {
  normalization
  validation
}

enum MenuVersionState {
  draft
  published
  archived
  superseded
}

model MenuImportJob {
  id                      String              @id @default(cuid())
  vendorId                String
  source                  MenuImportSource
  status                  MenuImportJobStatus @default(queued)
  deliverectChannelLinkId String?
  deliverectLocationId    String?
  deliverectMenuId        String?
  idempotencyKey          String?             @unique
  draftVersionId          String?             @unique
  draftVersion            MenuVersion?        @relation("MenuImportDraftVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)
  errorCode               String?
  errorMessage            String?
  startedAt               DateTime            @default(now())
  completedAt             DateTime?
  createdBy               String?

  vendor              Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  menuImportRawPayload MenuImportRawPayload?
  issues              MenuImportIssue[]

  @@index([vendorId, status])
  @@index([vendorId, startedAt(sort: Desc)])
}

model MenuImportRawPayload {
  id                   String        @id @default(cuid())
  jobId                String        @unique
  job                  MenuImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  deliverectApiVersion String?
  payload              Json
  payloadSha256        String
  createdAt            DateTime      @default(now())

  @@index([payloadSha256])
}

model MenuImportIssue {
  id               String                   @id @default(cuid())
  jobId            String
  job              MenuImportJob            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  kind             MenuImportIssueKind
  severity         MenuImportIssueSeverity
  code             String
  message          String
  entityPath       String?
  deliverectId     String?
  mennyuEntityType String?
  mennyuEntityId   String?
  details          Json?
  waived           Boolean                  @default(false)
  waivedBy         String?
  waivedAt         DateTime?

  @@index([jobId])
  @@index([jobId, severity])
}

model MenuVersion {
  id                         String            @id @default(cuid())
  vendorId                   String
  state                      MenuVersionState  @default(draft)
  canonicalSnapshot          Json
  canonicalSnapshotSha256    String
  previousPublishedVersionId String?
  previousPublishedVersion   MenuVersion?      @relation("MenuVersionHistory", fields: [previousPublishedVersionId], references: [id], onDelete: SetNull)
  nextVersions               MenuVersion[]     @relation("MenuVersionHistory")
  /// When set, this row was published by restoring the snapshot from the referenced (typically archived) MenuVersion.
  restoredFromMenuVersionId  String?
  restoredFromMenuVersion    MenuVersion?      @relation("MenuVersionRollbackSource", fields: [restoredFromMenuVersionId], references: [id], onDelete: SetNull)
  rollbacksDerivedFromThis   MenuVersion[]     @relation("MenuVersionRollbackSource")
  publishedAt                DateTime?
  publishedBy                String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  vendor              Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  jobPointingToDraft  MenuImportJob?  @relation("MenuImportDraftVersion")

  @@index([vendorId, state])
  @@index([vendorId, createdAt(sort: Desc)])
  @@index([vendorId, publishedAt(sort: Desc)])
}

model MenuItem {
  id                   String                  @id @default(cuid())
  vendorId             String
  name                 String
  description          String?
  priceCents           Int
  imageUrl             String?
  sortOrder            Int                     @default(0)
  isAvailable          Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  basketMaxQuantity    Int?
  deliverectProductId  String?
  /// Raw Deliverect `plu` from menu payload; snooze webhooks key on PLU while `deliverectProductId` is often `_id`-first.
  deliverectPlu        String?
  /// When this row is a Deliverect variation PLU, parent variant product PLU for outbound orders (`items[].subItems`).
  deliverectVariantParentPlu   String?
  /// Display name of the parent variant product (top-level order line `name`).
  deliverectVariantParentName  String?
  /// Deliverect category id from canonical menu (ordering / future grouping).
  deliverectCategoryId String?
  cartItems            CartItem[]
  vendor               Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  modifierGroups       MenuItemModifierGroup[]
  orderLines           OrderLineItem[]

  @@index([vendorId, deliverectCategoryId])
  @@index([vendorId, deliverectPlu])
}

model ModifierGroup {
  id                        String                  @id @default(cuid())
  vendorId                  String
  name                      String
  minSelections             Int                     @default(0)
  maxSelections             Int                     @default(1)
  isRequired                Boolean                 @default(false)
  sortOrder                 Int                     @default(0)
  isAvailable               Boolean                 @default(true)
  parentModifierOptionId    String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  /// Stable identity for Deliverect-first menu publish (upsert / soft-remove).
  deliverectModifierGroupId String?
  /// Deliverect `isVariantGroup` / productType 3 — options are nested `subItems`, not flat `modifiers`.
  deliverectIsVariantGroup    Boolean?
  menuItems                 MenuItemModifierGroup[]
  parentModifierOption      ModifierOption?         @relation("NestedModifierGroups", fields: [parentModifierOptionId], references: [id], onDelete: Cascade)
  vendor                    Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  options                   ModifierOption[]        @relation("GroupOptions")

  @@index([vendorId])
  @@index([parentModifierOptionId])
  @@index([vendorId, deliverectModifierGroupId])
}

model ModifierOption {
  id                      String                   @id @default(cuid())
  modifierGroupId         String
  name                    String
  priceCents              Int                      @default(0)
  sortOrder               Int                      @default(0)
  isDefault               Boolean                  @default(false)
  isAvailable             Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deliverectModifierId    String?
  /// Raw Deliverect `plu` for modifiers; channel order `plu` must match POS (not Mongo `_id`).
  deliverectModifierPlu   String?
  cartItemSelections      CartItemSelection[]
  nestedModifierGroups    ModifierGroup[]          @relation("NestedModifierGroups")
  modifierGroup           ModifierGroup            @relation("GroupOptions", fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderLineItemSelections OrderLineItemSelection[]

  @@index([modifierGroupId])
}

model MenuItemModifierGroup {
  id              String        @id @default(cuid())
  menuItemId      String
  modifierGroupId String
  required        Boolean       @default(false)
  minSelections   Int           @default(0)
  maxSelections   Int           @default(1)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierGroupId])
  @@index([menuItemId])
  @@index([modifierGroupId])
}

model Cart {
  id        String     @id @default(cuid())
  podId     String
  sessionId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  pod       Pod        @relation(fields: [podId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([podId, sessionId])
}

model CartItem {
  id                  String              @id @default(cuid())
  cartId              String
  menuItemId          String
  vendorId            String
  quantity            Int                 @default(1)
  priceCents          Int
  specialInstructions String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  cart                Cart                @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem            MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  vendor              Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  selections          CartItemSelection[]

  @@index([cartId])
  @@index([vendorId])
}

model CartItemSelection {
  id               String         @id @default(cuid())
  cartItemId       String
  modifierOptionId String
  quantity         Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cartItem         CartItem       @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, modifierOptionId])
  @@index([cartItemId])
  @@index([modifierOptionId])
}

model Order {
  id                    String               @id @default(cuid())
  podId                 String
  customerPhone         String
  customerEmail         String?
  subtotalCents         Int
  serviceFeeCents       Int
  tipCents              Int                  @default(0)
  taxCents              Int                  @default(0)
  totalCents            Int
  idempotencyKey        String?              @unique
  status                OrderStatus
  stripePaymentIntentId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  orderNotes            String?
  /// Shared admin notes for resolving exceptions on this order (not per-issue).
  adminResolutionNotes  String?
  /// Cart row used at checkout (line items cleared after payment / cancel). Optional for legacy orders.
  sourceCartId          String?
  /// Customer-requested pickup instant (UTC). Null = ASAP pickup.
  requestedPickupAt     DateTime?
  pod                   Pod                  @relation(fields: [podId], references: [id])
  issues                OrderIssue[]
  statusHistory         OrderStatusHistory[]
  payments              Payment[]
  refundAttempts        RefundAttempt[]
  vendorOrders          VendorOrder[]

  @@index([stripePaymentIntentId])
  @@index([sourceCartId])
}

model VendorOrder {
  id                      String                      @id @default(cuid())
  orderId                 String
  vendorId                String
  subtotalCents           Int
  tipCents                Int                         @default(0)
  taxCents                Int                         @default(0)
  serviceFeeCents         Int                         @default(0)
  totalCents              Int
  platformCommissionCents Int                         @default(0)
  deliverectOrderId       String?
  deliverectChannelLinkId String?
  routingStatus           VendorRoutingStatus
  fulfillmentStatus       VendorFulfillmentStatus
  lastDeliverectPayload   Json?
  lastWebhookPayload      Json?
  deliverectAttempts      Int                         @default(0)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  deliverectLastError     String?
  deliverectSubmittedAt   DateTime?
  lastDeliverectResponse  Json?
  manuallyRecoveredAt     DateTime?
  manuallyRecoveredBy     String?
  manualRecoveryNotes     String?
  statusAuthority         VendorOrderStatusAuthority?
  lastStatusSource        VendorOrderStatusSource?
  lastExternalStatus      String?
  lastExternalStatusAt    DateTime?
  /// Last Deliverect webhook apply outcome + debug fields (JSON)
  deliverectWebhookLastApply Json?
  lineItems               OrderLineItem[]
  paymentAllocations      PaymentAllocation[]
  order                   Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor                  Vendor                      @relation(fields: [vendorId], references: [id])
  issues                  VendorOrderIssue[]
  statusHistory           VendorOrderStatusHistory[]

  @@index([deliverectOrderId])
  @@index([orderId])
  @@index([vendorId])
}

model OrderLineItem {
  id                  String                   @id @default(cuid())
  vendorOrderId       String
  menuItemId          String
  name                String
  quantity            Int
  priceCents          Int
  specialInstructions String?
  createdAt           DateTime                 @default(now())
  menuItem            MenuItem                 @relation(fields: [menuItemId], references: [id])
  vendorOrder         VendorOrder              @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  selections          OrderLineItemSelection[]
}

model OrderLineItemSelection {
  id                 String         @id @default(cuid())
  orderLineItemId    String
  modifierOptionId   String
  nameSnapshot       String
  priceCentsSnapshot Int            @default(0)
  quantity           Int            @default(1)
  createdAt          DateTime       @default(now())
  modifierOption     ModifierOption @relation(fields: [modifierOptionId], references: [id])
  orderLineItem      OrderLineItem  @relation(fields: [orderLineItemId], references: [id], onDelete: Cascade)

  @@unique([orderLineItemId, modifierOptionId])
  @@index([orderLineItemId])
  @@index([modifierOptionId])
}

model Payment {
  id                        String              @id @default(cuid())
  orderId                   String
  stripePaymentIntentId     String              @unique
  amountCents               Int
  status                    PaymentStatus
  idempotencyKey            String?             @unique
  /// Stripe balance_transaction.fee for this charge (cents). Null = legacy / dev bypass / unavailable.
  stripeProcessingFeeCents  Int?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  order                    Order               @relation(fields: [orderId], references: [id])
  allocations              PaymentAllocation[]
}

model RefundAttempt {
  id                  String    @id @default(cuid())
  idempotencyKey      String    @unique
  orderId             String
  vendorOrderId       String?
  amountCents         Int
  status              String
  stripeRefundId      String?
  failureCode         String?
  failureMessage      String?
  reason              String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  /// When set, this failed attempt was dismissed as legacy/test; excluded from Needs Attention.
  dismissedAsLegacyAt DateTime?
  dismissedAsLegacyBy String?
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, status])
}

model PaymentAllocation {
  id                          String      @id @default(cuid())
  paymentId                   String
  vendorOrderId               String
  subtotalCents               Int
  tipCents                    Int         @default(0)
  taxCents                    Int         @default(0)
  serviceFeeCents             Int         @default(0)
  totalCents                  Int
  /// Immutable snapshot: subtotal + tax + tip (restaurant-facing; excludes Mennyu service fee).
  grossVendorPayableCents     Int
  /// This vendor's share of Payment.stripeProcessingFeeCents (largest-remainder split).
  allocatedProcessingFeeCents Int         @default(0)
  /// max(0, grossVendorPayableCents - allocatedProcessingFeeCents). Basis for future Connect transfers.
  netVendorTransferCents      Int
  createdAt                   DateTime    @default(now())
  payment                     Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  vendorOrder                 VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@unique([paymentId, vendorOrderId])
  @@index([paymentId])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  source    String?
  note      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model VendorOrderStatusHistory {
  id                String                      @id @default(cuid())
  vendorOrderId     String
  routingStatus     String?
  fulfillmentStatus String?
  source            String?
  rawPayload        Json?
  createdAt         DateTime                    @default(now())
  authority         VendorOrderStatusAuthority?
  statusSource      VendorOrderStatusSource?
  externalStatus    String?
  vendorOrder       VendorOrder                 @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId])
}

model OrderIssue {
  id         String    @id @default(cuid())
  orderId    String
  type       String
  severity   String
  status     String
  notes      String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  createdBy  String?
  resolvedBy String?
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, status])
}

model VendorOrderIssue {
  id            String      @id @default(cuid())
  vendorOrderId String
  type          String
  severity      String
  status        String
  notes         String?
  createdAt     DateTime    @default(now())
  resolvedAt    DateTime?
  createdBy     String?
  resolvedBy    String?
  vendorOrder   VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId])
  @@index([vendorOrderId, status])
}

model WebhookEvent {
  id             String    @id @default(cuid())
  provider       String
  eventId        String?
  idempotencyKey String?   @unique
  payload        Json
  processed      Boolean   @default(false)
  processedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  @@index([provider, eventId])
  @@index([idempotencyKey])
}

enum OrderStatus {
  pending_payment
  paid
  routing
  routed_partial
  routed
  accepted
  preparing
  ready
  completed
  cancelled
  failed
  in_progress
  partially_completed
}

enum VendorRoutingStatus {
  pending
  sent
  confirmed
  failed
}

enum VendorFulfillmentStatus {
  pending
  accepted
  preparing
  ready
  completed
  cancelled
}

enum PaymentStatus {
  requires_payment_method
  requires_confirmation
  requires_action
  processing
  succeeded
  canceled
}

enum VendorOrderStatusAuthority {
  pos
  dma
  vendor_manual
  admin_override
}

enum VendorOrderStatusSource {
  deliverect_webhook
  dma_action
  vendor_dashboard
  admin_action
  system
}
