// Mennyu MVP – Multi-vendor food cart pod ordering
// Money stored in cents (integer). Tax MVP = 0% with location-based design for later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums (status fields) ----
enum OrderStatus {
  pending_payment
  paid
  routing
  routed_partial
  routed
  accepted
  preparing
  ready
  in_progress
  partially_completed
  completed
  cancelled
  failed
}

enum VendorRoutingStatus {
  pending
  sent
  confirmed
  failed
}

enum VendorFulfillmentStatus {
  pending
  accepted
  preparing
  ready
  completed
  cancelled
}

enum PaymentStatus {
  requires_payment_method
  requires_confirmation
  requires_action
  processing
  succeeded
  canceled
}

// ---- Pods & Vendors ----
model Pod {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  address     String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendors    PodVendor[]
  carts      Cart[]
  orders     Order[]
  membershipRequests PodMembershipRequest[]
}

// Many-to-many: pod membership. Designed for future pod-owner invites/add-remove.
model PodVendor {
  id        String   @id @default(cuid())
  podId     String
  vendorId  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pod    Pod    @relation(fields: [podId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([podId, vendorId])
  @@index([podId])
  @@index([vendorId])
}

/// Pod membership request: pod owner requests vendor to join; vendor must accept or decline.
model PodMembershipRequest {
  id          String    @id @default(cuid())
  podId       String
  vendorId    String
  status      String    /// pending | accepted | declined | cancelled
  requestedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?

  pod    Pod    @relation(fields: [podId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([podId])
  @@index([vendorId])
  @@index([vendorId, status])
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  /// When true, block new Mennyu orders for this vendor (intake only); existing orders still visible.
mennyuOrdersPaused Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Deliverect: store/account identifiers once onboarding complete
  deliverectChannelLinkId String?  // Deliverect channel link ID for this vendor
  deliverectLocationId    String?  // Optional location ID
  deliverectAccountId     String?  // Account identifier for API calls

  pods        PodVendor[]
  menuItems   MenuItem[]
  modifierGroups ModifierGroup[]
  cartItems   CartItem[]
  vendorOrders VendorOrder[]
  podMembershipRequests PodMembershipRequest[]
}

model MenuItem {
  id          String   @id @default(cuid())
  vendorId    String
  name        String
  description String?
  priceCents  Int      // Always in cents
  imageUrl    String?
  sortOrder   Int      @default(0)
  isAvailable Boolean  @default(true)
  basketMaxQuantity Int?  // Optional multimax per product (Deliverect basket limits)
  deliverectProductId String?  // External product/PLU ID for Deliverect/POS mapping
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor    Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderLines OrderLineItem[]
  modifierGroups MenuItemModifierGroup[]
}

// ---- Modifiers (Deliverect-compliant structure) ----
// ModifierGroup: e.g. "Size", "Toppings". Can be nested under a ModifierOption.
model ModifierGroup {
  id                   String   @id @default(cuid())
  vendorId             String
  name                 String   // e.g. "Choose size"
  minSelections        Int      @default(0)
  maxSelections        Int      @default(1)
  isRequired           Boolean  @default(false)
  sortOrder            Int      @default(0)
  isAvailable          Boolean  @default(true)  // Snooze: hide when false
  parentModifierOptionId String? // When set, this group is nested under that option
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vendor           Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  parentModifierOption ModifierOption? @relation("NestedModifierGroups", fields: [parentModifierOptionId], references: [id], onDelete: Cascade)
  options          ModifierOption[] @relation("GroupOptions")
  menuItems        MenuItemModifierGroup[]

  @@index([vendorId])
  @@index([parentModifierOptionId])
}

model ModifierOption {
  id             String   @id @default(cuid())
  modifierGroupId String
  name          String   // e.g. "Extra cheese"
  priceCents     Int      @default(0)
  sortOrder      Int      @default(0)
  isDefault      Boolean  @default(false)  // Preselected when group is shown
  isAvailable    Boolean  @default(true)   // Snooze
  deliverectModifierId String?  // External modifier/PLU ID for Deliverect/POS mapping
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modifierGroup ModifierGroup @relation("GroupOptions", fields: [modifierGroupId], references: [id], onDelete: Cascade)
  nestedModifierGroups ModifierGroup[] @relation("NestedModifierGroups")
  cartItemSelections   CartItemSelection[]
  orderLineItemSelections OrderLineItemSelection[]

  @@index([modifierGroupId])
}

// Per-menu-item config: which modifier groups apply and min/max (overrides group defaults)
model MenuItemModifierGroup {
  id              String   @id @default(cuid())
  menuItemId      String
  modifierGroupId String
  required        Boolean  @default(false)
  minSelections   Int      @default(0)
  maxSelections   Int      @default(1)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierGroupId])
  @@index([menuItemId])
  @@index([modifierGroupId])
}

// ---- Cart (session-based; one cart per pod for simplicity) ----
model Cart {
  id        String   @id @default(cuid())
  podId     String
  sessionId String   // Cookie-based anonymous session
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pod  Pod       @relation(fields: [podId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([podId, sessionId])
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  menuItemId String
  vendorId   String
  quantity   Int      @default(1)
  priceCents Int      // Effective unit price at add-to-cart: base + sum(modifier price × qty); line total = priceCents × quantity
  specialInstructions String?  // Item-level notes (Deliverect item notes)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  selections CartItemSelection[]

  @@index([cartId])
  @@index([vendorId])
}

// Structured modifier selections per cart line (Deliverect-compliant; quantity supports "2x extra cheese")
model CartItemSelection {
  id             String   @id @default(cuid())
  cartItemId     String
  modifierOptionId String
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cartItem       CartItem      @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, modifierOptionId])
  @@index([cartItemId])
  @@index([modifierOptionId])
}

// ---- Parent order (one per checkout) ----
model Order {
  id                String   @id @default(cuid())
  podId             String
  customerPhone     String   // Primary notification channel
  customerEmail     String?
  orderNotes        String?  // Order-level notes (Deliverect order notes)
  // Totals in cents (customer-facing)
  subtotalCents     Int
  serviceFeeCents   Int     // 3.5% of subtotal
  tipCents          Int     @default(0)
  taxCents          Int     @default(0)
  totalCents        Int
  // Idempotency
  idempotencyKey    String?  @unique
  status            OrderStatus
  stripePaymentIntentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pod           Pod              @relation(fields: [podId], references: [id], onDelete: Restrict)
  vendorOrders  VendorOrder[]
  payments      Payment[]
  statusHistory OrderStatusHistory[]
  issues        OrderIssue[]

  @@index([stripePaymentIntentId])
}

// Child order per vendor; sent to Deliverect
model VendorOrder {
  id                  String   @id @default(cuid())
  orderId             String
  vendorId            String
  // Allocations in cents
  subtotalCents       Int
  tipCents            Int     @default(0)
  taxCents            Int     @default(0)
  serviceFeeCents     Int     @default(0)
  totalCents          Int
  // Platform commission (2.75% of vendor subtotal)
  platformCommissionCents Int @default(0)
  // Deliverect / POS
  deliverectOrderId   String?  // External ID from Deliverect
  deliverectChannelLinkId String?
  routingStatus       VendorRoutingStatus
  fulfillmentStatus   VendorFulfillmentStatus
  lastDeliverectPayload Json?   // Last request payload (audit)
  lastDeliverectResponse Json? // Last response payload (audit)
  deliverectSubmittedAt DateTime? // Timestamp of last submission attempt
  deliverectLastError  String?  // Last failure message/code when submission failed
  lastWebhookPayload   Json?
  deliverectAttempts   Int    @default(0)
  // Manual recovery: ops override when routing failed; preserves routing failure in audit.
  manuallyRecoveredAt  DateTime?
  manuallyRecoveredBy  String?
  manualRecoveryNotes  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor    Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lineItems OrderLineItem[]
  statusHistory VendorOrderStatusHistory[]
  paymentAllocations PaymentAllocation[]
  issues    VendorOrderIssue[]

  @@index([deliverectOrderId])
  @@index([orderId])
  @@index([vendorId])
}

model OrderLineItem {
  id           String   @id @default(cuid())
  vendorOrderId String
  menuItemId   String
  name         String   // Snapshot
  quantity     Int
  priceCents   Int      // Line unit price (base + modifier snapshot at order time)
  specialInstructions String?  // Item-level notes (Deliverect item notes)
  createdAt    DateTime @default(now())

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  selections  OrderLineItemSelection[]
}

// Snapshot of chosen modifiers per order line (audit + Deliverect payload)
model OrderLineItemSelection {
  id            String   @id @default(cuid())
  orderLineItemId String
  modifierOptionId String
  nameSnapshot  String   // e.g. "Extra cheese"
  priceCentsSnapshot Int  @default(0)
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())

  orderLineItem OrderLineItem @relation(fields: [orderLineItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Restrict)

  @@unique([orderLineItemId, modifierOptionId])
  @@index([orderLineItemId])
  @@index([modifierOptionId])
}

// Payment: one per order (single payer). Allocations stored for reconciliation.
model Payment {
  id                    String   @id @default(cuid())
  orderId               String
  stripePaymentIntentId String   @unique
  amountCents           Int
  status                PaymentStatus
  idempotencyKey        String?  @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order        Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  allocations  PaymentAllocation[]
}

// How the single payment is split (subtotal/tip/tax/fee per vendor for reporting)
model PaymentAllocation {
  id             String   @id @default(cuid())
  paymentId      String
  vendorOrderId  String
  subtotalCents  Int
  tipCents       Int      @default(0)
  taxCents       Int      @default(0)
  serviceFeeCents Int     @default(0)
  totalCents    Int
  createdAt      DateTime @default(now())

  payment    Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@unique([paymentId, vendorOrderId])
  @@index([paymentId])
}

// Audit trail for parent order status (unified customer view)
model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  source    String?  // system | deliverect | admin | fallback
  note      String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Per-vendor order status (for routing/fulfillment)
model VendorOrderStatusHistory {
  id            String   @id @default(cuid())
  vendorOrderId String
  routingStatus String?
  fulfillmentStatus String?
  source        String?
  rawPayload    Json?
  createdAt     DateTime @default(now())

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId])
}

// Operational issues (tracking only; does not change order lifecycle)
model OrderIssue {
  id        String    @id @default(cuid())
  orderId   String
  type      String    // routing_failure | partial_order | manual_refund | customer_issue | order_dispute | etc.
  severity  String    // LOW | MEDIUM | HIGH
  status    String    // OPEN | RESOLVED
  notes     String?
  createdAt DateTime  @default(now())
  resolvedAt DateTime?
  createdBy String?   // admin identifier if known
  resolvedBy String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, status])
}

model VendorOrderIssue {
  id            String    @id @default(cuid())
  vendorOrderId String
  type         String    // routing_failure | vendor_cancelled | delayed_vendor | partial_order | manual_recovery | etc.
  severity     String    // LOW | MEDIUM | HIGH
  status       String    // OPEN | RESOLVED
  notes        String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  createdBy    String?
  resolvedBy   String?

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId])
  @@index([vendorOrderId, status])
}

// Raw webhook events for idempotency and debugging
model WebhookEvent {
  id           String   @id @default(cuid())
  provider     String   // deliverect | stripe
  eventId      String?  // External event ID if provided
  idempotencyKey String? @unique // Hash of provider+eventId or body
  payload      Json
  processed    Boolean  @default(false)
  processedAt  DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([provider, eventId])
  @@index([idempotencyKey])
}
